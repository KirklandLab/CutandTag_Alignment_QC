##################################################################
##             Raw Fragment Length Files from Sorted BAM        ##
##################################################################

rule generate_fragmentLength_raw:
    input:
        bam_file="results/alignment/bam/{sample}.sorted.bam"
    output:
        fragLen="results/alignment/fragment_length/raw/{sample}_fragmentLen.raw.txt"
    envmodules:
        config["samtools"]
    threads: 2
    log: "results/logs/snakelogs/generate_fragmentLength_raw.{sample}.log"
    shell:
        """
        mkdir -p results/alignment/fragment_length/raw

        samtools view -@ {threads} -f 64 -F 12 {input.bam_file} | \
        awk -F'\\t' '$9 != 0 {{print ($9 < 0 ? -$9 : $9)}}' | \
        sort | uniq -c | \
        awk -v OFS="\\t" '{{print $2, $1}}' > {output.fragLen}
        """

##################################################################
##            Final Fragment Length Files from Analysis BAM     ##
##################################################################

rule generate_fragmentLength_final:
    input:
        bam_file=final_analysis_bam
    output:
        fragLen="results/alignment/fragment_length/final/{sample}_fragmentLen.final.txt"
    envmodules:
        config["samtools"]
    threads: 2
    log: "results/logs/snakelogs/generate_fragmentLength_final.{sample}.log"
    shell:
        """
        mkdir -p results/alignment/fragment_length/final

        samtools view -@ {threads} -f 64 -F 12 {input.bam_file} | \
        awk -F'\\t' '$9 != 0 {{print ($9 < 0 ? -$9 : $9)}}' | \
        sort | uniq -c | \
        awk -v OFS="\\t" '{{print $2, $1}}' > {output.fragLen}
        """

##################################################################
##                   Fragment Length Processing                 ##
##################################################################

rule process_fragment_length:
    input:
        bam_file=final_analysis_bam
    output:
        mapped_bam="results/alignment/bam/{sample}_bowtie2.mapped.bam",
        name_sorted_bam=temp("results/alignment/bam/{sample}_bowtie2.mapped.nameSorted.bam"),
        bed_file="results/alignment/bed/{sample}_bowtie2.bed",
        clean_bed="results/alignment/bed/{sample}_bowtie2.clean.bed",
        fragments_bed="results/alignment/bed/{sample}_bowtie2.fragments.bed",
        binned_counts="results/alignment/bed/{sample}_bowtie2.fragmentsCount.bin500.bed"
    params:
        binLen=500
    envmodules:
        config["samtools"],
        config["bedtools"]
    threads: 4
    log: "results/logs/snakelogs/process_fragment_length.{sample}.log"
    shell:
        """
        mkdir -p results/alignment/bed results/alignment/bam

        # Keep mapped reads from the final analysis BAM.
        samtools view -@ {threads} -b -F 0x0C {input.bam_file} -o {output.mapped_bam}

        # Name-sort before BEDPE conversion so mates are paired correctly.
        samtools sort -@ {threads} -n -o {output.name_sorted_bam} {output.mapped_bam}

        # Convert name-sorted BAM into BEDPE format.
        bedtools bamtobed -i {output.name_sorted_bam} -bedpe > {output.bed_file}

        # Keep read pairs on the same chromosome with fragment length less than 1000 bp.
        awk '$1==$4 && $6>$2 && $6-$2 < 1000 {{print $0}}' {output.bed_file} > {output.clean_bed}

        # Extract fragment coordinates.
        cut -f 1,2,6 {output.clean_bed} | sort -k1,1 -k2,2n -k3,3n > {output.fragments_bed}

        # Bin fragment counts by fragment midpoint.
        awk -v w={params.binLen} '{{print $1, int(($2 + $3)/(2*w))*w + w/2}}' {output.fragments_bed} | \
        sort -k1,1V -k2,2n | uniq -c | \
        awk -v OFS="\\t" '{{print $2, $3, $1}}' | sort -k1,1V -k2,2n > {output.binned_counts}
        """

