configfile: "config/config.yml"

##################################################################
##                         Author Info                          ##
##################################################################

# Author: Kevin A. Boyd
# Email: kevinboyd76@gmail.com
# GitHub: https://github.com/kevinboyd76
# Date Created: October 18, 2024
# Last Modified: June 17, 2026
# Version: 2.0.0
#
# Description: This Snakemake workflow processes CUT&Tag sequencing data
# from raw paired-end FASTQ files through optional raw FASTQ quality control,
# read alignment using Bowtie2, optional duplicate capping, optional random
# downsampling, BigWig signal track generation (raw, CPM-normalized, and
# target-scaled), peak calling via MACS2, fragment length analysis, and QC
# visualizations. The pipeline outputs normalized and scaled coverage tracks,
# per-sample peak files, FRiP scores, alignment summaries, duplicate/downsampling
# summaries, and plots to assess sample quality and replicate consistency.
#
# Update Version 2.0.0 (May/June 2026): This workflow now includes config controlled 
# toggles for raw FASTQ QC, duplicate capping, and random downsampling. Downsampling 
# can be run using a manual target, the lowest sample depth, or the lowest sample 
# depth above a minimum acceptable floor. Duplicate capping limits the number of
# identical fragments retained at each genomic position to reduce the influence
# of PCR duplicates while preserving controlled duplicate signal.
#
# Adapted from: Ye Zheng, Kami Ahmad, Steven Henikoff
# Original Protocol DOI: dx.doi.org/10.17504/protocols.io.bjk2kkye

##################################################################
##                    Specific Steps in Pipeline                ##
##################################################################

# Steps:
# 1) Optional quality control using FastQC (per read) and MultiQC (summary report)
# 2) Optional contamination check using FastQ Screen
# 3) Align reads to reference genome using Bowtie2 (paired-end)
# 4) Convert SAM to BAM, then sort and index BAM files
# 5) Optionally cap duplicate fragments by exact fragment coordinates
# 6) Optionally downsample post-cap or aligned BAMs to a defined fragment target
# 7) Define the final analysis BAM for each sample
# 8) Generate raw, CPM-normalized, and target-scaled BigWig signal tracks
# from the final analysis BAM
# 9) Calculate final analysis fragment counts and BigWig scale factors
# 10) Call peaks using MACS2 with fixed q-value threshold (per sample)
# 11) Extract raw and final fragment lengths from BAM files (per sample)
# 12) Plot fragment length distributions using R (violin and line plots)
# 13) Process final analysis BAMs to BEDPE/BED-style fragment data for QC
# 14) Calculate FRiP scores (Fraction of Reads in Peaks) for QC (per sample)
# 15) Generate correlation plot of binned fragment counts across samples
# 16) Create summary plots of alignment, duplicate/downsampling behavior,
# peak counts, and FRiP scores
#
# Outputs:
#    • Optional: FastQC and MultiQC HTML reports
#    • Optional: FastQ Screen PNG plots
#    • Bowtie2 alignment summaries
#    • Sorted BAM files and final analysis BAM files
#    • Duplicate-capping and downsampling metrics
#    • Raw, CPM-normalized, and target-scaled BigWig files
#    • MACS2 peak files (narrowPeak)
#    • Raw and final fragment length text files
#    • FRiP score tables
#    • Summary plots: alignment, duplicate/downsampling, fragment length, correlation, peak count, and FRiP

##################################################################
##                    Define input functions                    ##
##################################################################

import pandas as pd

# read the CSV file and set an index using the values in the "sample" column.
samples_table = pd.read_csv("config/samples.csv").set_index("sample", drop=False)

# fastq filename input function definition set to Python dictionary
def fq_dict_from_sample(wildcards):
  return {
    "fq1": samples_table.loc[wildcards.sample, "fastq1"],
    "fq2": samples_table.loc[wildcards.sample, "fastq2"]
  }

USE_FASTQ_QC = bool(config.get("use_fastq_qc", True))
USE_DUP_CAP = bool(config.get("use_duplicate_cap", False))
DUP_CAP_MAX = int(config.get("duplicate_cap_max", 0))

USE_DOWNSAMPLING = bool(config.get("use_downsampling", False))
DOWNSAMPLE_TARGET_MODE = str(config.get("downsample_target_mode", "manual"))
DOWNSAMPLE_TARGET = int(config.get("downsample_target_fragments", 0))
DOWNSAMPLE_MIN_FLOOR = int(config.get("downsample_minimum_acceptable_fragments", 0))
DOWNSAMPLE_SEED = config.get("downsample_seed", 12345)

VALID_DOWNSAMPLE_MODES = ["manual", "lowest_with_floor", "lowest"]

if DOWNSAMPLE_TARGET_MODE not in VALID_DOWNSAMPLE_MODES:
    raise ValueError(
        f"Invalid downsample_target_mode: {DOWNSAMPLE_TARGET_MODE}. "
        f"Choose one of: {VALID_DOWNSAMPLE_MODES}"
    )

MACS2_QVALUE = config["macs2_qvalue"]
MACS2_QVALUE_STR = str(MACS2_QVALUE)

PEAK_NAME_PATTERN = (
    f"results/peakCalling/"
    f"{{sample}}_{MACS2_QVALUE_STR}_peaks.narrowPeak"
)

##################################################################
##                 Conditional analysis BAM logic               ##
##################################################################

SAMPLES = list(samples_table.index)

FASTQC_OUTPUTS = (
    expand("results/qc/fastqc/{sample}_R1_fastqc.html", sample=SAMPLES) +
    expand("results/qc/fastqc/{sample}_R2_fastqc.html", sample=SAMPLES)
    if USE_FASTQ_QC else []
)

MULTIQC_OUTPUTS = (
    ["results/qc/multiqc/multiqc_report.html"]
    if USE_FASTQ_QC else []
)

FASTQ_SCREEN_OUTPUTS = (
    expand("results/qc/fastq_screen/{sample}_screen.png", sample=SAMPLES)
    if USE_FASTQ_QC else []
)

DUP_CAP_BAMS = (
    expand("results/alignment/bam/dedup_cap/{sample}.dupCap.bam", sample=SAMPLES)
    if USE_DUP_CAP else []
)

DUP_CAP_BAIS = (
    expand("results/alignment/bam/dedup_cap/{sample}.dupCap.bam.bai", sample=SAMPLES)
    if USE_DUP_CAP else []
)

DUP_CAP_METRICS = (
    expand("results/qc/duplicates/{sample}.duplicate_metrics.txt", sample=SAMPLES)
    if USE_DUP_CAP else []
)

DOWNSAMPLE_BAMS = (
    expand("results/alignment/bam/analysis/{sample}.analysis.bam", sample=SAMPLES)
    if USE_DOWNSAMPLING else []
)

DOWNSAMPLE_BAIS = (
    expand("results/alignment/bam/analysis/{sample}.analysis.bam.bai", sample=SAMPLES)
    if USE_DOWNSAMPLING else []
)

DOWNSAMPLE_METRICS = (
    expand("results/qc/downsampling/{sample}.downsample_metrics.txt", sample=SAMPLES)
    if USE_DOWNSAMPLING else []
)

DOWNSAMPLE_TARGET_FILE = ["results/qc/downsampling/downsample_target.txt"]

DUP_DOWNSAMPLE_SUMMARY_FILES = (
    [
        "results/qc/duplicates_downsampling/duplicate_downsampling_summary.tsv",
        "results/plots/duplicate_downsampling_summary.png"
    ]
    if (USE_DUP_CAP or USE_DOWNSAMPLING) else []
)


def post_dup_bam(wildcards):
    """
    BAM used as input to downsampling.
    If duplicate capping is enabled, use dupCap.bam.
    Otherwise use the original coordinate-sorted BAM.
    """
    if USE_DUP_CAP:
        return f"results/alignment/bam/dedup_cap/{wildcards.sample}.dupCap.bam"
    return f"results/alignment/bam/{wildcards.sample}.sorted.bam"


def post_dup_bai(wildcards):
    if USE_DUP_CAP:
        return f"results/alignment/bam/dedup_cap/{wildcards.sample}.dupCap.bam.bai"
    return f"results/alignment/bam/{wildcards.sample}.sorted.bam.bai"


def final_analysis_bam(wildcards):
    """
    Final BAM used by bigWig, MACS2, final fragment length, BEDPE, FRiP, and correlation.
    If downsampling is enabled, use analysis.bam.
    Else if duplicate capping is enabled, use dupCap.bam.
    Else use sorted.bam directly.
    """
    if USE_DOWNSAMPLING:
        return f"results/alignment/bam/analysis/{wildcards.sample}.analysis.bam"
    if USE_DUP_CAP:
        return f"results/alignment/bam/dedup_cap/{wildcards.sample}.dupCap.bam"
    return f"results/alignment/bam/{wildcards.sample}.sorted.bam"

##################################################################
##                          Rule All                            ##
##################################################################

rule all:
    input:
        FASTQC_OUTPUTS,
        MULTIQC_OUTPUTS,
        FASTQ_SCREEN_OUTPUTS,
        expand("results/alignment/sam/{sample}_bowtie2.sam", sample=samples_table.index),
        expand("results/alignment/bam/{sample}_bowtie2.bam", sample=samples_table.index),
        expand("results/alignment/bam/{sample}.sorted.bam", sample=samples_table.index),
        DUP_CAP_BAMS,
        DUP_CAP_BAIS,
        DUP_CAP_METRICS,
        DOWNSAMPLE_BAMS,
        DOWNSAMPLE_BAIS,
        DOWNSAMPLE_METRICS,
        DOWNSAMPLE_TARGET_FILE,
        DUP_DOWNSAMPLE_SUMMARY_FILES,
        expand("results/alignment/bigwig/scale_reads/{sample}_analysis_fragments.txt", sample=samples_table.index),
        expand("results/alignment/bigwig/scale_reads/{sample}_analysis_scale_factor.txt", sample=samples_table.index),
        expand("results/alignment/bigwig/{sample}_analysis.bw", sample=samples_table.index),
        expand("results/alignment/bigwig/{sample}_analysisCPM.bw", sample=samples_table.index),
        expand("results/alignment/bigwig/{sample}_analysisScaled.bw", sample=samples_table.index),
        expand(PEAK_NAME_PATTERN, sample=samples_table.index),
        expand("results/alignment/fragment_length/raw/{sample}_fragmentLen.raw.txt", sample=samples_table.index),
        expand("results/alignment/fragment_length/final/{sample}_fragmentLen.final.txt", sample=samples_table.index),
        "results/plots/fragment_length_plot.png",
        "results/plots/alignment_summary_plot.png",
        expand("results/alignment/bed/{sample}_bowtie2.fragmentsCount.bin500.bed", sample=samples_table.index),
        expand("results/alignment/bam/{sample}_frip.txt", sample=samples_table.index),
        "results/plots/fragCount_correlation_plot.pdf",
        "results/plots/peak_summary_plot.png",
        "results/plots/peak_summary_report.pdf"

##################################################################
##                       Quality Control                        ##
##################################################################

# run fastqc on fastq.gz files before trimming
rule fastqc_reads:
    input:
        unpack(fq_dict_from_sample)
    output:
        html1="results/qc/fastqc/{sample}_R1_fastqc.html",
        zip1="results/qc/fastqc/{sample}_R1_fastqc.zip",
        html2="results/qc/fastqc/{sample}_R2_fastqc.html",
        zip2="results/qc/fastqc/{sample}_R2_fastqc.zip"
    envmodules:
        config["fastqc"]
    threads: 4
    log: "results/logs/snakelogs/fastqc_reads.{sample}.log"
    shell:
        """
        # Run FastQC with output directed to writable folder
        fastqc -t {threads} -o results/qc/fastqc {input.fq1}
        fastqc -t {threads} -o results/qc/fastqc {input.fq2}

        # Rename output files to match specified output paths
        dir="results/qc/fastqc"
        bsename=$(basename {input.fq1} .gz)
        bsename=$(basename ${{bsename}} .fastq)
        mv ${{dir}}/${{bsename}}_fastqc.html {output.html1}
        mv ${{dir}}/${{bsename}}_fastqc.zip {output.zip1}
        
        bsename=$(basename {input.fq2} .gz)
        bsename=$(basename ${{bsename}} .fastq)
        mv ${{dir}}/${{bsename}}_fastqc.html {output.html2}
        mv ${{dir}}/${{bsename}}_fastqc.zip {output.zip2}
        """

##################################################################
##                     Multiqc on Raw Fastqs                    ##
##################################################################

rule multiqc_raw:
    input:
        expand("results/qc/fastqc/{sample}_R1_fastqc.zip", sample=samples_table.index),
        expand("results/qc/fastqc/{sample}_R2_fastqc.zip", sample=samples_table.index)
    output:
        "results/qc/multiqc/multiqc_report.html"
    params:
        outdir="results/qc/multiqc"
    envmodules:
        config["multiqc"]
    threads: 4
    log:
        "results/logs/multiqc/multiqc.log"
    shell:
        """
        rm -rf {params.outdir}
        mkdir -p {params.outdir}
        multiqc results/qc/fastqc -o {params.outdir} 2> {log}
        """

##################################################################
##                         Fastq Screen                         ##
##################################################################

rule fastq_screen:
    input:
        unpack(fq_dict_from_sample)
    output:
        fastq_info="results/qc/fastq_screen/{sample}_screen.png"
    params:
        out_dir="results/qc/fastq_screen",
        config_file="resources/fastq_screen.conf"
    envmodules:
        config["fastq_screen"]
    threads: 4
    log: "results/logs/snakelogs/fastq_screen.{sample}.log"
    shell:
        """
        fastq_screen --conf {params.config_file} --threads {threads} --outdir {params.out_dir} {input.fq1}
        
        # Extract the base name without .fastq.gz
        base_name=$(basename {input.fq1} .fastq.gz)
        
        # Move or link the output file to the expected output
        mv {params.out_dir}/${{base_name}}_screen.png {output.fastq_info}
        """

##################################################################
##                       Read Alignment                         ##
##################################################################

rule align_with_bowtie2:
    input:
        unpack(fq_dict_from_sample)
    output:
        sam_file="results/alignment/sam/{sample}_bowtie2.sam",
        bowtie2_summary="results/alignment/sam/bowtie2_summary/{sample}_bowtie2.txt"
    params:
        bowtie2_genome=config["bowtie2_genome"]
    envmodules:
        config["bowtie2"]
    threads: 16
    log: "results/logs/snakelogs/align_with_bowtie2.{sample}.log"
    shell:
        """
        bowtie2 --end-to-end --very-sensitive --no-mixed --no-discordant --phred33 -I 10 -X 700 \
        -p {threads} \
        -x {params.bowtie2_genome} \
        -1 {input.fq1} -2 {input.fq2} -S {output.sam_file} &> {output.bowtie2_summary}
        """

##################################################################
##                     SAM to BAM Conversion                    ##
##################################################################

rule sam_to_bam:
    input:
        sam_file="results/alignment/sam/{sample}_bowtie2.sam"
    output:
        bam_file="results/alignment/bam/{sample}_bowtie2.bam"
    envmodules:
        config["samtools"]
    threads: 4
    log: "results/logs/snakelogs/sam_to_bam.{sample}.log"
    shell:
        """
        samtools view -@ {threads} -bS {input.sam_file} > {output.bam_file}
        """

##################################################################
##                  BAM Sorting and Indexing                    ##
##################################################################

rule sort_bam:
    input:
        bam_file="results/alignment/bam/{sample}_bowtie2.bam"
    output:
        sorted_bam="results/alignment/bam/{sample}.sorted.bam",
        bai="results/alignment/bam/{sample}.sorted.bam.bai"
    envmodules:
        config["samtools"]
    threads: 4
    log: "results/logs/snakelogs/sort_bam.{sample}.log"
    shell:
        """
        samtools sort -@ {threads} -o {output.sorted_bam} {input.bam_file}
        samtools index -@ {threads} {output.sorted_bam} {output.bai}
        """

##################################################################
##              Duplicate Capping by Fragment Coordinate        ##
##################################################################

rule cap_duplicate_fragments:
    input:
        sorted_bam="results/alignment/bam/{sample}.sorted.bam",
        bai="results/alignment/bam/{sample}.sorted.bam.bai"
    output:
        bam="results/alignment/bam/dedup_cap/{sample}.dupCap.bam",
        bai="results/alignment/bam/dedup_cap/{sample}.dupCap.bam.bai",
        names="results/qc/duplicates/{sample}.dupCap.keep_names.txt",
        metrics="results/qc/duplicates/{sample}.duplicate_metrics.txt"
    params:
        max_dups=lambda wildcards: DUP_CAP_MAX if USE_DUP_CAP else 0
    envmodules:
        config["samtools"]
    threads: 4
    log:
        "results/logs/snakelogs/cap_duplicate_fragments.{sample}.log"
    shell:
        """
        mkdir -p results/alignment/bam/dedup_cap results/qc/duplicates

        samtools view -@ {threads} {input.sorted_bam} | \
        python scripts/select_duplicate_capped_names.py \
            --sample {wildcards.sample} \
            --max-dups {params.max_dups} \
            --names-out {output.names} \
            --metrics-out {output.metrics}

        samtools view -@ {threads} -b -N {output.names} {input.sorted_bam} | \
            samtools sort -@ {threads} -o {output.bam}

        samtools index -@ {threads} {output.bam} {output.bai}
        """

##################################################################
##             Calculate Analysis/Downsampling Target           ##
##################################################################

rule calculate_downsample_target:
    input:
        bams=lambda wildcards: [
            f"results/alignment/bam/dedup_cap/{sample}.dupCap.bam"
            if USE_DUP_CAP else
            f"results/alignment/bam/{sample}.sorted.bam"
            for sample in samples_table.index
        ]
    output:
        target="results/qc/downsampling/downsample_target.txt"
    params:
        use_downsampling=USE_DOWNSAMPLING,
        mode=DOWNSAMPLE_TARGET_MODE,
        manual_target=DOWNSAMPLE_TARGET,
        floor=DOWNSAMPLE_MIN_FLOOR
    envmodules:
        config["samtools"]
    threads: 2
    log:
        "results/logs/snakelogs/calculate_downsample_target.log"
    shell:
        """
        mkdir -p results/qc/downsampling

        echo -e "target_fragments\\tmode\\tlowest_fragments\\tlowest_above_floor\\tfloor\\tmanual_target\\tdownsampling_enabled\\tnote" > {output.target}

        lowest=""
        lowest_above_floor=""

        for bam in {input.bams}; do
            count=$(samtools view -@ {threads} -c -f 64 -F 12 $bam)

            if [ -z "$lowest" ] || [ "$count" -lt "$lowest" ]; then
                lowest=$count
            fi

            if [ "{params.floor}" -gt 0 ] && [ "$count" -ge "{params.floor}" ]; then
                if [ -z "$lowest_above_floor" ] || [ "$count" -lt "$lowest_above_floor" ]; then
                    lowest_above_floor=$count
                fi
            fi
        done

        # If downsampling is disabled, use the empirical lowest final-analysis
        # fragment count as the BigWig scaling target only.
        if [ "{params.use_downsampling}" != "True" ]; then
            target=$lowest
            note="downsampling_disabled_lowest_used_for_bigwig_scaling"

            echo -e "$target\\tno_downsampling\\t$lowest\\t$lowest_above_floor\\t{params.floor}\\tNA\\t{params.use_downsampling}\\t$note" >> {output.target}
            exit 0
        fi

        if [ "{params.mode}" = "manual" ]; then
            target="{params.manual_target}"
            note="manual_target_used"

            echo -e "$target\\tmanual\\t$lowest\\t$lowest_above_floor\\t{params.floor}\\t{params.manual_target}\\t{params.use_downsampling}\\t$note" >> {output.target}
            exit 0
        fi

        if [ "{params.mode}" = "lowest" ]; then
            target=$lowest
            note="lowest_sample_used_no_floor"

            echo -e "$target\\tlowest\\t$lowest\\t$lowest_above_floor\\t{params.floor}\\tNA\\t{params.use_downsampling}\\t$note" >> {output.target}
            exit 0
        fi

        if [ "{params.mode}" = "lowest_with_floor" ]; then
            if [ -n "$lowest_above_floor" ]; then
                target=$lowest_above_floor
                note="lowest_sample_at_or_above_floor_used"
            else
                target=$lowest
                note="no_sample_met_floor_lowest_sample_used"
            fi

            echo -e "$target\\tlowest_with_floor\\t$lowest\\t$lowest_above_floor\\t{params.floor}\\tNA\\t{params.use_downsampling}\\t$note" >> {output.target}
            exit 0
        fi
        """

##################################################################
##             Optional: Downsampling After Dup Cap             ##
##################################################################

rule downsample_analysis_bam:
    input:
        bam=post_dup_bam,
        bai=post_dup_bai,
        target="results/qc/downsampling/downsample_target.txt"
    output:
        bam="results/alignment/bam/analysis/{sample}.analysis.bam",
        bai="results/alignment/bam/analysis/{sample}.analysis.bam.bai",
        metrics="results/qc/downsampling/{sample}.downsample_metrics.txt"
    params:
        use_downsampling=USE_DOWNSAMPLING,
        seed=DOWNSAMPLE_SEED
    envmodules:
        config["samtools"]
    threads: 4
    log:
        "results/logs/snakelogs/downsample_analysis_bam.{sample}.log"
    shell:
        """
        mkdir -p results/alignment/bam/analysis results/qc/downsampling

        target=$(awk 'NR==2 {{print $1}}' {input.target})
        target_mode=$(awk 'NR==2 {{print $2}}' {input.target})
        target_enabled=$(awk 'NR==2 {{print $7}}' {input.target})
        target_note=$(awk 'NR==2 {{print $8}}' {input.target})

        # Count mapped read1 records as mapped fragments/read pairs.
        fragments_before=$(samtools view -@ {threads} -c -f 64 -F 12 {input.bam})

        if [ "{params.use_downsampling}" = "True" ] && [ "$target" -gt 0 ] && [ "$fragments_before" -gt "$target" ]; then
            fraction=$(awk -v target="$target" -v total="$fragments_before" 'BEGIN {{ printf "%.10f", target / total }}')

            seed_arg=""
            if [ "{params.seed}" != "none" ] && [ "{params.seed}" != "None" ] && [ "{params.seed}" != "" ]; then
                seed_arg="--subsample-seed {params.seed}"
            fi

            samtools view -@ {threads} -b \
                $seed_arg \
                --subsample $fraction \
                {input.bam} | \
                samtools sort -@ {threads} -o {output.bam}

            action="downsampled"
        else
            cp {input.bam} {output.bam}
            action="not_downsampled"
            fraction="1.0000000000"
        fi

        samtools index -@ {threads} {output.bam} {output.bai}

        fragments_after=$(samtools view -@ {threads} -c -f 64 -F 12 {output.bam})

        echo -e "Sample\\tAction\\tTargetMode\\tDownsamplingEnabled\\tTargetNote\\tTargetFragments\\tSeed\\tSubsampleFraction\\tFragmentsBeforeDownsample\\tFragmentsAfterDownsample" > {output.metrics}
        echo -e "{wildcards.sample}\\t$action\\t$target_mode\\t$target_enabled\\t$target_note\\t$target\\t{params.seed}\\t$fraction\\t$fragments_before\\t$fragments_after" >> {output.metrics}
        """

##################################################################
##             Duplicate + Downsampling Metrics Summary         ##
##################################################################

rule summarize_duplicate_metrics:
    input:
        dup_metrics=DUP_CAP_METRICS,
        down_metrics=DOWNSAMPLE_METRICS,
        down_target=DOWNSAMPLE_TARGET_FILE,
        metadata="config/samples.csv"
    output:
        combined_summary="results/qc/duplicates_downsampling/duplicate_downsampling_summary.tsv",
        plot="results/plots/duplicate_downsampling_summary.png"
    params:
        out_dir="results/plots"
    envmodules:
        config["R"],
        config["bioconductor"]
    threads: 2
    log:
        "results/logs/snakelogs/summarize_duplicate_metrics.log"
    shell:
        """
        mkdir -p results/qc/duplicates_downsampling results/plots

        dup_metrics_arg="{input.dup_metrics}"
        down_metrics_arg="{input.down_metrics}"
        down_target_arg="{input.down_target}"

        if [ -z "$dup_metrics_arg" ]; then
            dup_metrics_arg="NA"
        fi

        if [ -z "$down_metrics_arg" ]; then
            down_metrics_arg="NA"
        fi

        if [ -z "$down_target_arg" ]; then
            down_target_arg="NA"
        fi

        Rscript scripts/plot_duplicate_metrics.R \
            "$dup_metrics_arg" \
            "$down_metrics_arg" \
            "$down_target_arg" \
            {input.metadata} \
            {output.combined_summary} \
            {output.plot}
        """

##################################################################
##          Final Analysis Fragments and BW Scale Factor        ##
##################################################################

rule calculate_analysis_scale_factor:
    input:
        bam=final_analysis_bam,
        target="results/qc/downsampling/downsample_target.txt"
    output:
        total_fragments="results/alignment/bigwig/scale_reads/{sample}_analysis_fragments.txt",
        scale_factor="results/alignment/bigwig/scale_reads/{sample}_analysis_scale_factor.txt"
    envmodules:
        config["samtools"]
    threads: 2
    log: "results/logs/snakelogs/calculate_analysis_scale_factor.{sample}.log"
    shell:
        """
        mkdir -p results/alignment/bigwig/scale_reads

        target=$(awk 'NR==2 {{print $1}}' {input.target})

        # Count mapped read1 records as mapped fragments/read pairs.
        fragments=$(samtools view -@ {threads} -c -f 64 -F 12 {input.bam})

        if [ "$fragments" -gt 0 ] && [ "$target" -gt 0 ]; then
            scale_factor=$(awk -v target="$target" -v fragments="$fragments" 'BEGIN {{ printf "%.10f", target / fragments }}')
        else
            scale_factor="1.0000000000"
        fi

        echo $fragments > {output.total_fragments}
        echo $scale_factor > {output.scale_factor}
        """

##################################################################
##                       BigWig Generation                      ##
##################################################################

rule make_bigwigs:
    input:
        bam=final_analysis_bam,
        scale_factor="results/alignment/bigwig/scale_reads/{sample}_analysis_scale_factor.txt"
    output:
        bigwig="results/alignment/bigwig/{sample}_analysis.bw",
        bigwig_cpm="results/alignment/bigwig/{sample}_analysisCPM.bw",
        bigwig_scaled="results/alignment/bigwig/{sample}_analysisScaled.bw"
    params:
        genome_size=config["effective_genome_size"],
        binSize=config["binSize"]
    envmodules:
        config["deeptools"]
    threads: 8
    log: "results/logs/snakelogs/make_bigwigs.{sample}.log"
    shell:
        """
        # Analysis BigWig
        bamCoverage -p {threads} -b {input.bam} -o {output.bigwig} \
            --effectiveGenomeSize {params.genome_size} \
            --binSize {params.binSize}

        # CPM BigWig
        bamCoverage -p {threads} -b {input.bam} -o {output.bigwig_cpm} \
            --effectiveGenomeSize {params.genome_size} \
            --binSize {params.binSize} \
            --normalizeUsing CPM

        # Scaled-to-target BigWig
        scale_factor=$(cat {input.scale_factor})
        bamCoverage -p {threads} -b {input.bam} -o {output.bigwig_scaled} \
            --effectiveGenomeSize {params.genome_size} \
            --binSize {params.binSize} \
            --scaleFactor $scale_factor
        """

##################################################################
##                        MACS2 Peak Calling                    ##
##################################################################

rule macs2_peak_calling:
    input:
        bam=final_analysis_bam
    output:
        peaks=PEAK_NAME_PATTERN
    params:
        genome=config["genome_size"],
        qvalue=MACS2_QVALUE,
        prefix=lambda wildcards: (
            f"{wildcards.sample}_{MACS2_QVALUE_STR}"
        ),
        output_dir="results/peakCalling/"
    envmodules:
        config["macs2"]
    threads: 8
    log:
        "results/logs/snakelogs/macs2_peak_calling.{sample}.log"
    shell:
        """
        mkdir -p {params.output_dir}

        macs2 callpeak \
            -t {input.bam} \
            -g {params.genome} \
            -f BAMPE \
            -n {params.prefix} \
            --outdir {params.output_dir} \
            -q {params.qvalue} \
            --keep-dup all \
            --nomodel \
            2> {params.output_dir}/{params.prefix}_macs2Peak_summary.txt
        """

