##################################################################
##                        Calculate FRiP                        ##
##################################################################

rule calculate_frip:
    input:
        fragments_bed="results/alignment/bed/{sample}_bowtie2.fragments.bed",
        peak_bed=PEAK_NAME_PATTERN
    output:
        frip_data="results/alignment/bam/{sample}_frip.txt"
    envmodules:
        config["bedtools"]
    threads: 2
    log: "results/logs/snakelogs/calculate_frip.{sample}.log"
    shell:
        """
        total_fragments=$(wc -l < {input.fragments_bed})

        if [ "$total_fragments" -eq 0 ]; then
            frip="0"
            intersected="0"
        else
            intersected=$(bedtools intersect -a {input.fragments_bed} -b {input.peak_bed} -u | wc -l)
            frip=$(echo "scale=4; ($intersected / $total_fragments) * 100" | bc)
        fi

        echo -e "Sample\\tTotalFragments\\tFragmentsInPeaks\\tFRiP" > {output.frip_data}
        echo -e "{wildcards.sample}\\t$total_fragments\\t$intersected\\t$frip" >> {output.frip_data}
        """

